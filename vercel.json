{
  "redirects": [
    {
      "source": "/:path.html",
      "destination": "/:path",
      "permanent": true
    },
    {
      "source": "/:path.php",
      "destination": "/:path",
      "permanent": true
    },
    {
      "source": "https://www.:host/:path*",
      "destination": "https://:host/:path*",
      "permanent": true
    },
    {
      "source": "http://:host/:path*",
      "destination": "https://:host/:path*",
      "permanent": true
    },
    {
      "source": "/index",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}